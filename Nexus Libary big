                local pickerFrame = nil

                local function OpenPicker()
                    if pickerFrame then pickerFrame:Destroy() end
                    pickerFrame = Instance.new("Frame")
                    pickerFrame.BackgroundColor3 = BG_ELEMENT
                    pickerFrame.Size = UDim2.new(0, 260, 0, 310)
