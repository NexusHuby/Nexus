                task.spawn(function() pcall(Info.Callback,true) end)
            end)
        else
            tries = tries + 1
            TweenService:Create(inStroke,T_FAST,{Color=Color3.fromRGB(220,70,70),Transparency=0}):Play()
            if Info.MaxTries > 0 and tries >= Info.MaxTries then
