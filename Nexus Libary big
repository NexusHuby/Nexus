-- Helpers
local function AddCorner(p, r)
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 6); c.Parent = p; return c
end
local function AddStroke(p, col, thick, trans)
    local s = Instance.new("UIStroke"); s.Color = col or SEP; s.Thickness = thick or 1
    s.Transparency = trans or 0; s.Parent = p; return s
end
local function TextH(text, size, font, width)
    local ok, b = pcall(function()
        return TextService:GetTextSize(text, size, font, Vector2.new(width, 9999))
    end)
    return ok and b.Y or size + 4
end

