-- MOUSE XY HELPER
function library:GetXY(obj)
    local max = obj.AbsoluteSize.X
    return math.clamp(Mouse.X - obj.AbsolutePosition.X, 0, max) / max, 0
end

-- COLOR UTILITIES
local function ColorToHex(c)
    return string.format("%02X%02X%02X",
        math.floor(c.R*255+.5), math.floor(c.G*255+.5), math.floor(c.B*255+.5))
end
local function HexToColor(hex)
    hex = hex:gsub("#",""):upper()
    if #hex == 6 then
        local r = tonumber(hex:sub(1,2),16); local g = tonumber(hex:sub(3,4),16); local b = tonumber(hex:sub(5,6),16)
        if r and g and b then return Color3.fromRGB(r,g,b) end
    end
    return nil
end

