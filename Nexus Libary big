    function window:SettingsTab(Opts)
        Opts = Opts or {}; Opts.Icon = Opts.Icon or nil
        local st = window:Tab({ Text = "Settings", Icon = Opts.Icon })
        local function Serialize()
            local data = {}
            for flag, entry in pairs(winFlags) do
                local v = entry.get()
                if entry.type=="boolean" or entry.type=="number" or entry.type=="string" then data[flag]=v
                elseif entry.type=="keycode" then local name="NONE"; if v then pcall(function() name=tostring(v):match("%.(%w+)$") or "NONE" end) end; data[flag]={__type="keycode",name=name}
                elseif entry.type=="color3" and v then data[flag]={__type="color3",r=v.R,g=v.G,b=v.B} end
            end
            return HttpService:JSONEncode(data)
        end
        local function ApplyData(data)
            for flag, val in pairs(data) do
                local entry = winFlags[flag]; if entry then
                    if type(val)=="table" and val.__type=="keycode" then local kc=nil; if val.name and val.name~="NONE" then pcall(function() kc=Enum.KeyCode[val.name] end) end; pcall(entry.set,kc)
                    elseif type(val)=="table" and val.__type=="color3" then pcall(entry.set, Color3.new(val.r,val.g,val.b))
                    else pcall(entry.set, val) end
                end
            end
        end
        local function GetName()
            local n=(library.Flags["_sb_cfg_name"] or ""):gsub("[^%w_%-]","_"); return (n ~= "" and n) or "default"
        end
        local leftSec  = st:Section({ Text="Config",    Side="Left",  Open=true })
        local rightSec = st:Section({ Text="Community", Side="Right", Open=true })
        local statusLbl = leftSec:Label({ Text="Ready.", Color=TXT3 })
