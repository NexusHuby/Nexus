            else
                local rem = (Info.MaxTries>0) and ("  ("..tostring(Info.MaxTries-tries).." left)") or ""
                statusLbl.Text = "  Invalid key"..rem
            end
            task.delay(2,function()
                TweenService:Create(inStroke,T_FAST,{Color=SEP,Transparency=0}):Play()
                if tries < Info.MaxTries or Info.MaxTries == 0 then statusLbl.Text = "" end
            end)
        end
    end
    cfBtn.MouseButton1Click:Connect(CheckKey)
    keyBox.FocusLost:Connect(function(enter) if enter then CheckKey() end end)
end

