    local function CheckKey()
        local entered = keyBox.Text:match("^%s*(.-)%s*$")
        if entered == Info.Key then
            if Info.SaveKey then pcall(function() writefile(CFG_FOLDER.."/_key.dat", Info.Key) end) end
            statusLbl.Text = "  Authenticated!"; statusLbl.TextColor3 = ACH
            task.delay(.5,function()
                TweenService:Create(card,T_MED,{BackgroundTransparency=1,Position=UDim2.new(.5,0,.44,0)}):Play()
